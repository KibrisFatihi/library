@model List<Kutuphane.Models.Member
>

@{
    ViewData["Title"] = "Üye Listesi";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="premium-dashboard py-5">
    <div class="blur-circle circle-1"></div>
    <div class="blur-circle circle-2"></div>
    <div class="blur-circle circle-3"></div>
    <div class="container relative-content">
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
            <a href="/Home/Index" class="btn btn-green btn-sm">
                <i class="bi bi-house"></i> Ana Menü
            </a>
        <h2 class="fw-bold text-white"><i class="bi bi-journal-text text-primary"></i> Kütüphane Üye Listesi</h2>
            <div class="d-flex gap-2">
        <a href="@Url.Action("Ekle", "Member")" class="btn btn-primary shadow-sm">
            <i class="bi bi-journal-plus"></i> Yeni Üye Ekle
        </a>
        <a href="@Url.Action("Arsiv", "Member")" class="btn btn-primary shadow-sm">
            <i class="bi bi-journal-plus"></i> Arşivlenen üyeler
        </a>
    </div>
    </div>

    <table class="table table-bordered table-striped shadow-sm bg-white rounded">
        <thead class="table-dark">
            <tr>
                <th>Üye Numarası</th>
                <th>Üye TC No</th>
                <th>Üye Adı</th>
                <th>Üye Soy Adı</th>
                <th>Üye Telefon</th>
                <th>Üye E Posta</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var member in Model)
                {
                    <tr>

                        <td class="fw-bold text-secondary">@member.Id</td>
                        <td>@member.Tc</td>
                        <td>@member.FirstName</td>
                        <td>@member.LastName</td>
                        <td>@member.Telephone</td>
                        <td>@member.Mail</td>
                    
                        <td>
                            <a href="@Url.Action("Duzenle", "Member", new { id = member.Id })" class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-pencil-square"></i> Düzenle
                            </a>
                            <a href="@Url.Action("Sil", "Member", new { id = member.Id })" class="btn btn-sm btn-danger" onclick="return confirm('Bu üyeyi silmek istediğinize emin misiniz ?')">
                                <i class="bi bi-trash3"></i> Sil
                            </a>
                </td>
                    </tr>

                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="bi bi-exclamation-circle fs-3 d-block mb-2 text-warning"></i>
                        Veri tabanında henüz üye bulunamadı veya bağlantı kurulamadı.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        <a href="/Home/Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Modüllere Geri Dön
        </a>
    </div>
</div>
</div>
</div>

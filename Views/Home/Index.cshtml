@{
    ViewData["Title"] = "Kütüphane Yönetim Paneli";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div class="fw-bold text-primary fs-3 d-flex align-items-center gap-2">
            <i class="bi bi-book-half"></i>
            <span>Kütüphane Portal</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary btn-sm px-3 rounded-pill fw-semibold"><i class="bi bi-box-arrow-in-right"></i> Giriş Yap</button>
            <button class="btn btn-primary btn-sm px-3 rounded-pill fw-semibold"><i class="bi bi-person-plus-fill"></i> Üye Ol</button>
        </div>
    </div>

    <div class="p-5 mb-5 bg-white rounded-3 shadow-sm text-center border">
        <div class="py-2">
            <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2 rounded-pill fw-semibold text-uppercase">Bulut Tabanlı Otomasyon</span>
            <h1 class="display-5 fw-bold text-dark">Merkezi Kütüphane Yönetim Sistemi</h1>
            <p class="col-md-8 mx-auto lead text-muted mt-3">
                Supabase bulut altyapısı ve .NET Core gücüyle geliştirilmiş yeni nesil yönetim paneli.
                Aşağıdan işlem yapmak istediğiniz aktif modülü seçerek devam edebilirsiniz kanka.
            </p>
        </div>
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-md-4">
            <a href="/Book/Index" class="text-decoration-none text-dark d-block h-100">
                <div class="card h-100 shadow-sm border-0 text-center p-4 bg-light modul-kart aktif-kart">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <div class="mb-3 ic-ikon text-primary">
                            <i class="bi bi-journal-bookmark-fill" style="font-size: 3.5rem;"></i>
                        </div>
                        <h4 class="card-title fw-bold text-dark">Kitap Yönetimi</h4>
                        <p class="card-text text-muted small mt-2">Kitap ekleme, silme, düzenleme ve raf konumlandırma işlemlerini yönet kanka.</p>
                        <span class="text-primary fw-semibold mt-3 small">Giriş Yapmak İçin Tıkla →</span>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 text-center p-4 bg-light modul-kart pasif-kart">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="mb-3 ic-ikon text-success opacity-50">
                        <i class="bi bi-person-badge-fill" style="font-size: 3.5rem;"></i>
                    </div>
                    <h4 class="card-title fw-bold text-muted">Üye Yönetimi</h4>
                    <p class="card-text text-muted small mt-2">Kütüphaneye kayıtlı öğrencileri, üyelik tiplerini ve aktiflik durumlarını takip et.</p>
                    <span class="text-secondary fw-semibold mt-3 small">Pazartesi Gelecek ⏳</span>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 text-center p-4 bg-light modul-kart pasif-kart">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="mb-3 ic-ikon text-warning opacity-50">
                        <i class="bi bi-book-half" style="font-size: 3.5rem;"></i>
                    </div>
                    <h4 class="card-title fw-bold text-muted">Ödünç & Ceza</h4>
                    <p class="card-text text-muted small mt-2">Kitap teslim süreçleri, süre takibi ve geciken günler için ceza hesaplama merkezi.</p>
                    <span class="text-secondary fw-semibold mt-3 small">Yakında ⏳</span>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .modul-kart {
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border-radius: 15px !important;
    }

    .aktif-kart:hover {
        transform: translateY(-8px);
        background-color: #ffffff !important;
        box-shadow: 0 15px 30px rgba(13, 110, 253, 0.12) !important;
    }

        .aktif-kart:hover .ic-ikon {
            transform: scale(1.1);
            transition: transform 0.2s ease;
        }

    .pasif-kart {
        opacity: 0.7;
        cursor: not-allowed;
    }
</style>
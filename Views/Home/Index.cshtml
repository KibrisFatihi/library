@{
    ViewData["Title"] = "Kütüphane Yönetim Paneli";
}

<link rel="stylesheet" href="/css/dashboard.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div class="premium-dashboard">
    <div class="blur-circle circle-1"></div>
    <div class="blur-circle circle-2"></div>
    <div class="blur-circle circle-3"></div>

    <div class="container relative-content">

        <div class="dashboard-header d-flex justify-content-between align-items-center mb-5 animate-fade-in">
            <div class="fw-extrabold text-gradient fs-2 d-flex align-items-center gap-3">
                <div class="logo-box">
                    <i class="bi bi-book-half"></i>
                </div>
                <span class="brand-text">Kütüphane Portal</span>
            </div>
            <div class="d-flex gap-3">
                <a href="/Account/Logout" class="btn btn-neon rounded-pill px-4 py-2 fw-bold shadow">
                    <i class="fas fa-sign-out-alt me-2"></i> Güvenli Çıkış
                </a>
            </div>
        </div>

        <div class="hero-glass-card text-center mb-5 animate-slide-up">
            <span class="badge bg-neon-pulse mb-3 px-3 py-2 rounded-pill fw-bold text-uppercase">
                <span class="pulse-dot"></span> Bulut Tabanlı Otomasyon
            </span>
            <h1 class="display-4 fw-extrabold text-dark tracking-tight">Merkezi Kütüphane Otomasyonu</h1>
            <p class="col-md-8 mx-auto lead text-secondary mt-3 fw-medium">
                Supabase bulut mimarisi ve .NET Core gücüyle modernize edilmiş yeni nesil yönetim ekosistemi.
            </p>
        </div>

        <div class="row g-4 justify-content-center animate-cards-up">

            <div class="col-md-4">
                <a href="/Book/Index" class="text-decoration-none d-block h-100">
                    <div class="card glow-card border-0 p-4 h-100 card-primary">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-4">
                                    <div class="module-icon icon-primary">
                                        <i class="bi bi-bookmarks-fill"></i>
                                    </div>
                                    <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold shadow-sm">@ViewBag.TotalBooks Adet</span>
                                </div>
                                <h4 class="card-title fw-bold text-dark mb-2">Kitap Yönetimi</h4>
                                <p class="card-text text-secondary small line-height-relaxed">Kitap envanterini, dinamik raf konumlarını ve arşiv süreçlerini jilet gibi yönet kanka.</p>
                            </div>
                            <div class="card-footer-glow mt-4 border-top pt-3 d-flex align-items-center justify-content-between">
                                <span class="footer-text fw-semibold small">Yönetime Başla</span>
                                <div class="arrow-circle"><i class="bi bi-arrow-right-short"></i></div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="/Member/Index" class="text-decoration-none d-block h-100">
                    <div class="card glow-card border-0 p-4 h-100 card-success">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-4">
                                    <div class="module-icon icon-success">
                                        <i class="bi bi-people"></i>
                                    </div>
                                    <span class="badge bg-success rounded-pill px-3 py-2 fw-bold shadow-sm">@ViewBag.TotalMembers Üye</span>
                                </div>
                                <h4 class="card-title fw-bold text-dark mb-2">Üye Yönetimi</h4>
                                <p class="card-text text-secondary small line-height-relaxed">Öğrenci kayıtlarını, üyelik statülerini ve aktif/pasif durumlarını anlık takip et.</p>
                            </div>
                            <div class="card-footer-glow mt-4 border-top pt-3 d-flex align-items-center justify-content-between">
                                <span class="footer-text fw-semibold small">Yönetime Başla</span>
                                <div class="arrow-circle"><i class="bi bi-arrow-right-short"></i></div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="/Loan/Index" class="text-decoration-none d-block h-100">
                    <div class="card glow-card border-0 p-4 h-100 card-warning">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-4">
                                    <div class="module-icon icon-warning">
                                        <i class="bi bi-arrow-left-right"></i>
                                    </div>
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2 fw-bold shadow-sm">@ViewBag.ActiveLoans Aktif</span>
                                </div>
                                <h4 class="card-title fw-bold text-dark mb-2">Ödünç İşlemleri</h4>
                                <p class="card-text text-secondary small line-height-relaxed">Emanet kitap verme, geri alma, stok senkronizasyonu ve limitleri kontrol et.</p>
                            </div>
                            <div class="card-footer-glow mt-4 border-top pt-3 d-flex align-items-center justify-content-between">
                                <span class="footer-text fw-semibold small">Yönetime Başla</span>
                                <div class="arrow-circle"><i class="bi bi-arrow-right-short"></i></div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

        </div>

        </div>
    </div>

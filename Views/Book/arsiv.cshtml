@model List<Kutuphane.Models.Book>

@{
    ViewData["Title"] = "Arsiv Kitap Listesi";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-journal-text text-primary"></i> Kütüphane Kitap Listesi</h2>
     
    </div>

    <table class="table table-bordered table-striped shadow-sm bg-white rounded">
        <thead class="table-dark">
            <tr>
                <th>Kapak</th>
                <th>Kitap ID</th>
                <th>Kitap Adı</th>
                <th>Yazar</th>
                <th>Sayfa Sayısı</th>
                <th>Raf</th>
                <th>Sıra Sayısı</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var kitap in Model)
                {
                    <tr>
                        <td class="text-center" style="width: 70px;">
                            @if (!string.IsNullOrEmpty(kitap.BookImageUrl))
                            {
                                <img src="@kitap.BookImageUrl" alt="Kapak" class="img-thumbnail shadow-sm" style="width: 50px; height: 70px; object-fit: cover; border-radius: 6px;" />
                            }
                            else
                            {
                                <div class="bg-light border rounded d-flex align-items-center justify-content-center text-muted" style="width: 50px; height: 70px;">
                                    <i class="bi bi-book" style="font-size: 1.2rem;"></i>
                                </div>
                            }
                        <td class="fw-bold text-secondary">@kitap.BookId</td>

                        <td>@kitap.BookName</td>
                        <td>@kitap.BookAuthor</td>
                        <td>@kitap.BookPage</td>
                        <td><span class="badge bg-info text-dark">@kitap.Location?.raf</span></td>
                        <td><span class="badge bg-light text-dark border">@kitap.Location?.sira</span></td>
                        <td>
                            <a href="@Url.Action("GeriAl", "Book", new { id = kitap.BookId })" class="btn btn-sm btn-success" onclick="return confirm('Bu kitabı arşivden çıkartıp kütüphaneye geri getirmek istediğine emin misin kanka?')">
                                <i class="bi bi-arrow-counterclockwise"></i> Geri Al
                            </a>

                            <a href="@Url.Action("KaliciSil", "Book", new { id = kitap.BookId })" class="btn btn-sm btn-danger" onclick="return confirm('DİKKAT! Bu kitap veritabanından TAMAMEN silinecek. Emin misin kanka?')">
                                <i class="bi bi-trash3-fill"></i> Kalıcı Sil
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="bi bi-exclamation-circle fs-3 d-block mb-2 text-warning"></i>
                        Veri tabanında henüz kitap bulunamadı veya bağlantı kurulamadı.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        <a href="/Home/Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Modüllere Geri Dön
        </a>
    </div>
</div>
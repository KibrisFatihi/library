@model List<Kutuphane.Models.Book>

@{
    ViewData["Title"] = "Kitap Listesi";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-journal-text text-primary"></i> Kütüphane Kitap Listesi</h2>

        <div class="d-flex gap-2">
            <a href="@Url.Action("Ekle", "Book")" class="btn btn-primary shadow-sm">
                <i class="bi bi-journal-plus"></i> Yeni Kitap Ekle
            </a>
            <a href="@Url.Action("Arsiv", "Book")" class="btn btn-secondary shadow-sm">
                <i class="bi bi-archive-fill"></i> Arşivlenen Kitaplar
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <form asp-controller="Book" asp-action="Index" method="get" class="d-flex gap-2">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           name="searchString"
                           class="form-control border-start-0"
                           placeholder="Kitap adı veya yazar ara..."
                           value="@ViewBag.CurrentFilter" />
                </div>
                <button type="submit" class="btn btn-primary px-4 fw-semibold">Ara</button>

                @if (!string.IsNullOrEmpty(ViewBag.CurrentFilter))
                {
                    <a href="/Book/Index" class="btn btn-outline-secondary">Temizle</a>
                }
            </form>
        </div>
    </div>

    <table class="table table-bordered table-striped shadow-sm bg-white rounded align-middle">
        <thead class="table-dark">
            <tr>
                <th class="text-center">Kapak</th>
                <th>Kitap ID</th>
                <th>Kitap Adı</th>
                <th>Yazar</th>
                <th>Sayfa Sayısı</th>
                <th>Raf</th>
                <th>Sıra Sayısı</th>
                <th class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var kitap in Model)
                {
                    <tr>
                        <td class="text-center" style="width: 70px;">
                            @if (!string.IsNullOrEmpty(kitap.BookImageUrl))
                            {
                                <img src="@kitap.BookImageUrl" alt="Kapak" class="img-thumbnail shadow-sm" style="width: 50px; height: 70px; object-fit: cover; border-radius: 6px;" />
                            }
                            else
                            {
                                <div class="bg-light border rounded d-flex align-items-center justify-content-center text-muted mx-auto" style="width: 50px; height: 70px;">
                                    <i class="bi bi-book" style="font-size: 1.2rem;"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-bold text-secondary">@kitap.BookId</td>
                        <td>@kitap.BookName</td>
                        <td>@kitap.BookAuthor</td>
                        <td>@kitap.BookPage</td>
                        <td><span class="badge bg-info text-dark">@kitap.Location?.raf</span></td>
                        <td><span class="badge bg-light text-dark border">@kitap.Location?.sira</span></td>
                        <td class="text-center">
                            <a href="@Url.Action("Duzenle", "Book", new { id = kitap.BookId })" class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-pencil-square"></i> Düzenle
                            </a>
                            <a href="@Url.Action("Sil", "Book", new { id = kitap.BookId })" class="btn btn-sm btn-danger" onclick="return confirm('Bu kitabı silmek istediğinize emin misiniz kanka?')">
                                <i class="bi bi-trash3"></i> Sil
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">
                        <i class="bi bi-exclamation-circle fs-3 d-block mb-2 text-warning"></i>
                        Aradığınız kriterlere uygun kitap bulunamadı kanka.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        <a href="/Home/Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Modüllere Geri Dön
        </a>
    </div>
</div>
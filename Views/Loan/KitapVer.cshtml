@model Kutuphane.Models.Readingbook
@{
    ViewData["Title"] = "Kitap Ödünç Verme İşlemi";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow p-4 bg-white rounded">
            <h3 class="fw-bold mb-4 text-primary"><i class="bi bi-journal-arrow-up"></i> Kitap Ödünç Ver</h3>
            @if (ViewBag.HataMesaji != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Hata:</strong> @ViewBag.HataMesaji
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            <form asp-controller="Loan" asp-action="KitapVer" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">Kitap Verilecek Üye</label>
                    <select name="MemberId" class="form-select" required>
                        <option value="">-- Lütfen Üye Seç kanka --</option>
                        @if (ViewBag.Uyeler != null)
                        {
                            foreach (var uye in ViewBag.Uyeler)
                            {
                                <option value="@uye.Id">@uye.FirstName @uye.LastName (TC: @uye.Tc)</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Ödünç Verilecek Kitap</label>
                    <select name="BookId" class="form-select" required>
                        <option value="">-- Lütfen Kitap Seç kanka --</option>
                        @if (ViewBag.Kitaplar != null)
                        {
                            foreach (var kitap in ViewBag.Kitaplar)
                            {
                                <option value="@kitap.BookId">@kitap.BookName - @kitap.BookAuthor</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Tahmini İade Tarihi</label>
                    <input type="date" name="ReturnDate" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/Loan/Index" class="btn btn-outline-secondary">Vazgeç</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle-fill"></i> Kitabı Ödünç Ver
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
    
    

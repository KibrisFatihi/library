@model List<Kutuphane.Models.Readingbook>

@{
    ViewData["Title"] = "Ödünç Verilen Kitaplar";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">
            <i class="bi bi-book-half text-primary"></i> Ödünç Verilen Kitap Listesi
        </h2>
        <a href="/Loan/KitapVer" class="btn btn-primary shadow-sm">
            <i class="bi bi-journal-arrow-up"></i> Yeni Kitap Ödünç Ver
        </a>
    </div>

    <table class="table table-bordered table-striped shadow-sm bg-white rounded align-middle">
        <thead class="table-dark">
            <tr>
                <th>İşlem ID</th>
                <th>Kitap Adı</th>
                <th>Teslim Alan Üye</th>
                <th>Veriliş Tarihi</th>
                <th>Tahmini İade Tarihi</th>
                <th>Durum</th>
                <th class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var odunc in Model)
                {
                    <tr>
                        <td class="fw-bold text-secondary">#@odunc.Id</td>

                        <td>@(odunc.Book != null ? odunc.Book.BookName : $"Kitap ID: {odunc.BookId}")</td>
                        <td>@(odunc.Member != null ? $"{odunc.Member.FirstName} {odunc.Member.LastName}" : $"Üye ID: {odunc.MemberId}")</td>

                        <td>@DateTime.Now.ToString("dd.MM.yyyy")</td> @* Geçici veya veritabanındaki borrow_date alanı *@
                        <td>@(odunc.ReturnDate.HasValue ? odunc.ReturnDate.Value.ToString("dd.MM.yyyy") : "-")</td>

                        <td>
                            <span class="badge bg-warning text-dark">Okuyucuda</span>
                        </td>
                        <td class="text-center">
                            <a href="/Loan/ReturnBook/@odunc.Id" class="btn btn-sm btn-success" onclick="return confirm('Bu kitabın iade edildiğini onaylıyor musun kanka?')">
                                <i class="bi bi-journal-check"></i> İade Al
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="bi bi-info-circle fs-3 d-block mb-2 text-info"></i>
                        Şu anda dışarıda (ödünçte) olan herhangi bir kitap bulunmuyor kanka.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        <a href="/Home/Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Modüllere Geri Dön
        </a>
    </div>
</div>
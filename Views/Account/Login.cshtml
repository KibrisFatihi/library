@using Kutuphane.Models
@{
    Layout = null; // Giriş sayfasında üst menü (navbar) görünmesin kanka, tam ekran premium olsun
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Siber Kütüphane - Giriş Yap</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="premium-dashboard d-flex align-items-center justify-content-center" style="min-height: 100vh;">

    <div class="blur-circle circle-1"></div>
    <div class="blur-circle circle-2"></div>
    <div class="blur-circle circle-3"></div>

    <div class="container relative-content" style="max-width: 450px;">
        <div class="hero-glass-card p-5 rounded-4 border-0 shadow-lg text-center animate-fade-in">

            <div class="logo-box mx-auto mb-4" style="width: 60px; height: 60px; font-size: 1.8rem;">
                <i class="bi bi-shield-lock-fill"></i>
            </div>

            <h2 class="text-white fw-extrabold mb-2">Hoş Geldiniz</h2>
            <p class="text-muted small mb-4">Siber Kütüphane Otomasyonuna erişmek için kimliğini doğrula.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger bg-danger-neon border-0 text-danger rounded-3 small p-2 mb-3 text-start">
                    <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                </div>
            }

            <form action="/Account/Login" method="post" class="text-start">

                <div class="mb-3">
                    <label class="form-label form-label-custom">E-Posta Adresi</label>
                    <div class="input-group">
                        <span class="input-group-text custom-glass-input border-end-0" style="border-top-right-radius: 0 !important; border-bottom-right-radius: 0 !important;">
                            <i class="bi bi-envelope text-muted"></i>
                        </span>
                        <input type="email" name="email" class="form-control custom-glass-input border-start-0" style="border-top-left-radius: 0 !important; border-bottom-left-radius: 0 !important;" placeholder="demo@mail.com" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label form-label-custom">Şifre</label>
                    <div class="input-group">
                        <span class="input-group-text custom-glass-input border-end-0" style="border-top-right-radius: 0 !important; border-bottom-right-radius: 0 !important;">
                            <i class="bi bi-key text-muted"></i>
                        </span>
						<input type="password" name="password" class="form-control custom-glass-input border-start-0" style="border-top-left-radius: 0 !important; border-bottom-left-radius: 0 !important;" placeholder="demo" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-neon w-100 py-3 rounded-3 fw-bold mb-3">
                    Sisteme Giriş Yap <i class="bi bi-arrow-right-short fs-5 align-middle"></i>
                </button>

                <div class="text-center mt-3">
                    <p class="text-muted small mb-0">Hesabın yok mu? <a href="/Account/Register" class="text-info text-decoration-none fw-semibold">Hemen Üye Ol </a></p>
                </div>
            </form>

        </div>
    </div>

</body>
</html>
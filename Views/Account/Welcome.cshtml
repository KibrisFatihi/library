@{
    Layout = null; // Bağımsız kurumsal sinematik dış arayüz
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Siber Kütüphane - Kurumsal Tanıtım Kataloğu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Bootstrap Icons eklendi -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        /* ÖLÇEKLENDİRME KRİZLERİNİ ÇÖZEN ÖZEL CSS DOKUNUŞLARI  */
        html, body {
            background-color: #0b0f19 !important;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            width: 100%;
        }
        /* Görsel form elemanları için özel premium cam efekti */
        .demo-input {
            background: rgba(255, 255, 255, 0.03) !important;
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
            color: #94a3b8 !important;
        }

            .demo-input::placeholder {
                color: #475569 !important;
            }
    </style>
</head>
<body class="premium-dashboard">

    <div class="blur-circle circle-1" style="width: 500px; height: 500px; background: rgba(0, 210, 255, 0.07); top: -5%; left: -5%;"></div>
    <div class="blur-circle circle-2" style="width: 500px; height: 500px; background: rgba(163, 54, 255, 0.06); bottom: 10%; right: -5%;"></div>

    <nav class="navbar navbar-expand-lg border-bottom border-secondary border-opacity-25 py-3 relative-content">
        <div class="container">
            <a class="navbar-brand text-white fw-extrabold fs-4 mb-0" href="#">
                <i class="fas fa-book-reader text-neon me-2"></i>SİBER KÜTÜPHANE
            </a>
            <div class="d-flex gap-2 ms-auto">
                <a href="/Account/Login" class="btn btn-glass btn-sm rounded-pill px-4 text-white fw-semibold">Giriş Yap</a>
                <a href="/Account/Register" class="btn btn-neon btn-sm rounded-pill px-4 fw-bold shadow">Kayıt Ol</a>
            </div>
        </div>
    </nav>

    <section class="container relative-content pt-4 pt-md-5 pb-2">
        <div class="hero-glass-card p-4 p-md-5 rounded-5 border-0 shadow-2xl mb-4 text-center animate-slide-up" style="background: rgba(15, 23, 42, 0.45); border: 1px solid rgba(255, 255, 255, 0.05) !important;">
            <span class="badge bg-gradient-cyan text-dark fw-bold px-3 py-2 rounded-pill mb-3">V3.0 ENTEGRE SEYİR SİSTEMİ</span>
            <h1 class="text-white fw-extrabold display-4 mb-3" style="letter-spacing: -1.5px; line-height: 1.2;">
                Geleceğin Dijital <span style="background: linear-gradient(to right, #00d2ff, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Arşivleme Altyapısı</span>
            </h1>
            <p class="text-muted fs-5 mx-auto mb-4" style="max-width: 680px;">
                Google API optimizasyonlu katman yapısı, Supabase şifreleme zırhı ve canlı kurumsal grafik analiz veri akışıyla siber kütüphane ağındasın .
            </p>
            <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                <a href="/Account/Login" class="btn btn-neon btn-lg rounded-pill px-5 py-3 fw-bold shadow-lg fs-6">
                    Sisteme Giriş Yap <i class="fas fa-box-arrow-in-right ms-2"></i>
                </a>
                <a href="#katalog" class="btn btn-glass btn-lg rounded-pill px-5 py-3 text-white border-secondary fs-6">
                    Kataloğu Keşfet <i class="fas fa-arrow-down ms-2"></i>
                </a>
            </div>
        </div>
    </section>

    <section class="container relative-content pb-4 animate-fade-in">
        <div class="row g-4 match-height-container">

            <!-- SOL KOLON: 3'LÜ İSTATİSTİK KARTLARI -->
            <div class="col-lg-4 col-md-12">
                <div class="row g-3 h-100 flex-column justify-content-between">
                    <div class="col-12 flex-grow-1">
                        <div class="hero-glass-card p-4 rounded-4 border-0 text-center equal-height-card">
                            <h4 class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px;">Toplam Katalog Verisi</h4>
                            <span class="text-white h2 fw-extrabold text-neon mb-0">@ViewBag.ToplamKitap</span>
                        </div>
                    </div>
                    <div class="col-12 flex-grow-1">
                        <div class="hero-glass-card p-4 rounded-4 border-0 text-center equal-height-card">
                            <h4 class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px;">Aktif Dijital Okuyucu</h4>
                            <span class="text-success h2 fw-extrabold mb-0">@ViewBag.AktifUye</span>
                        </div>
                    </div>
                    
                </div>
            </div>

            <!-- SAĞ KOLON: AYNI KARTTA BİRLEŞEN GRAFİK VE GÖRSEL GİRİŞ FORMU -->
            <div class="col-lg-8 col-md-12">
                <div class="hero-glass-card p-4 rounded-4 border-0 h-100 d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="text-white fw-bold mb-3">
                            <i class="fas fa-chart-line text-info me-2"></i> Aylık Ödünç & İade Trafiği Analizi
                        </h5>
                    </div>

                    <!-- İç Grid: Sol taraf grafik, sağ taraf görsel form -->
                    <div class="row align-items-center g-3">
                        <div class="col-xl-7 col-lg-12">
                            <div class="chart-container-fixed" style="height: 280px; position: relative;">
                                <canvas id="tanitimGrafigi"></canvas>
                            </div>
                        </div>

                        <div class="col-xl-5 col-lg-12">
                            <div class="p-3 rounded-4" style="background: rgba(15, 23, 42, 0.5); border: 1px solid rgba(0, 210, 255, 0.15);">
                                <h6 class="text-white fw-bold mb-3 small text-uppercase" style="letter-spacing: 0.5px;">
                                    <i class="fas fa-lock text-neon me-2"></i> Hızlı Sistem Girişi
                                </h6>
                                <form onsubmit="return false;">
                                    <div class="mb-2">
                                        <label class="text-muted small mb-1" style="font-size: 11px;">E-Posta Adresi</label>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text demo-input border-end-0">
                                                <i class="bi bi-envelope text-muted"></i>
                                            </span>
                                            <input type="email" class="form-control demo-input border-start-0" value="demo@mail.com" readonly />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="text-muted small mb-1" style="font-size: 11px;">Şifre</label>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text demo-input border-end-0">
                                                <i class="bi bi-key text-muted"></i>
                                            </span>
                                            <input type="text" class="form-control demo-input border-start-0" value="demo" readonly />
                                        </div>
                                    </div>

                                    <button type="button" class="btn btn-neon w-100 py-2 btn-sm rounded-3 fw-bold opacity-75" style="cursor: not-allowed;">
                                        Sisteme Giriş Yap <i class="bi bi-arrow-right-short align-middle"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

    <section class="container relative-content py-4 py-md-5" id="katalog">

        <div class="row mb-4 animate-fade-in">
            <div class="col-12">
                <h3 class="text-white fw-extrabold mb-1">
                    <i class="fas fa-cubes text-neon me-2"></i> Kütüphane Core Kurumsal Altyapısı
                </h3>
                <p class="text-muted small">Sistemin arka planında çalışan, veri entegrasyonu tamamlanmış diğer gelişmiş kütüphane bileşenleri.</p>
            </div>
        </div>

        <div class="row g-4 animate-fade-in">

            <div class="col-xl-4 col-md-6">
                <div class="hero-glass-card p-4 rounded-4 border-0 h-100 feature-showcase-card">
                    <div class="d-flex align-items-center mb-3">
                        <div class="logo-box me-3" style="width: 45px; height: 45px; font-size: 1.2rem; background: rgba(0, 210, 255, 0.15); color: #00d2ff;">
                            <i class="fas fa-book"></i>
                        </div>
                        <div>
                            <h5 class="text-white fw-bold mb-0">Kataloglama</h5>
                            <span class="text-muted small">Kitap ve Materyal Yönetimi</span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-light opacity-75 small ps-2 border-start border-secondary border-opacity-25">
                        <li class="mb-2"><i class="fas fa-plus-circle text-info me-2"></i> Kitap Ekleme Modülü</li>
                        <li class="mb-2"><i class="fas fa-list text-info me-2"></i> Detaylı Kitap Listesi</li>
                        <li class="mb-2"><i class="fas fa-user-edit text-info me-2"></i> Yazar Yönetim Paneli</li>
                        <li class="mb-2"><i class="fas fa-database text-info me-2"></i> Okuma Listeleri Havuzu</li>
                        <li class="mb-2"><i class="fas fa-star text-info me-2"></i> 300.000+ Hazır Kitap Havuzu</li>
                    </ul>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="hero-glass-card p-4 rounded-4 border-0 h-100 feature-showcase-card">
                    <div class="d-flex align-items-center mb-3">
                        <div class="logo-box me-3" style="width: 45px; height: 45px; font-size: 1.2rem; background: rgba(163, 54, 255, 0.15); color: #a336ff;">
                            <i class="fas fa-users"></i>
                        </div>
                        <div>
                            <h5 class="text-white fw-bold mb-0">Üye Yönetimi</h5>
                            <span class="text-muted small">Okuyucu ve Personel</span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-light opacity-75 small ps-2 border-start border-secondary border-opacity-25">
                        <li class="mb-2"><i class="fas fa-user-plus text-purple me-2"></i> Dijital Üye Kayıt Sistemi</li>
                        <li class="mb-2"><i class="fas fa-address-book text-purple me-2"></i> Kurumsal Üye Listesi</li>
                        <li class="mb-2"><i class="fas fa-award text-purple me-2"></i> Üye Rozet & Gamification</li>
                        <li class="mb-2"><i class="fas fa-certificate text-purple me-2"></i> Dijital Sertifika Oluşturma</li>
                        <li class="mb-2"><i class="fas fa-id-card text-purple me-2"></i> Akıllı Üye Kartı Basımı</li>
                    </ul>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="hero-glass-card p-4 rounded-4 border-0 h-100 feature-showcase-card">
                    <div class="d-flex align-items-center mb-3">
                        <div class="logo-box me-3" style="width: 45px; height: 45px; font-size: 1.2rem; background: rgba(16, 185, 129, 0.15); color: #10b981;">
                            <i class="fas fa-exchange-alt"></i>
                        </div>
                        <div>
                            <h5 class="text-white fw-bold mb-0">Ödünç İşlemleri</h5>
                            <span class="text-muted small">Verme ve İade Mekanizması</span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-light opacity-75 small ps-2 border-start border-secondary border-opacity-25">
                        <li class="mb-2"><i class="fas fa-hand-holding text-success me-2"></i> Ödünç Verme Modülü</li>
                        <li class="mb-2"><i class="fas fa-undo text-success me-2"></i> Akıllı İade Al Sistemi</li>
                        <li class="mb-2"><i class="fas fa-clock text-success me-2"></i> Güvenli Süre Uzatma</li>
                        <li class="mb-2"><i class="fas fa-history text-success me-2"></i> Geri Dönüşüm Günlükleri</li>
                        <li class="mb-2"><i class="fas fa-coins text-success me-2"></i> Gecikme Cezası Hesaplama</li>
                    </ul>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="hero-glass-card p-4 rounded-4 border-0 h-100 feature-showcase-card">
                    <div class="d-flex align-items-center mb-3">
                        <div class="logo-box me-3" style="width: 45px; height: 45px; font-size: 1.2rem; background: rgba(249, 115, 22, 0.15); color: #f97316;">
                            <i class="fas fa-chart-pie"></i>
                        </div>
                        <div>
                            <h5 class="text-white fw-bold mb-0">Raporlama</h5>
                            <span class="text-muted small">İstatistik ve Derin Analiz</span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-light opacity-75 small ps-2 border-start border-secondary border-opacity-25">
                        <li class="mb-2"><i class="fas fa-chart-line text-warning me-2"></i> Grafiksel İstatistik Verileri</li>
                        <li class="mb-2"><i class="fas fa-trophy text-warning me-2"></i> Anlık Canlı Rapor Özeti</li>
                        <li class="mb-2"><i class="fas fa-file-excel text-warning me-2"></i> Excel/PDF Rapor Çıktısı</li>
                    </ul>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="hero-glass-card p-4 rounded-4 border-0 h-100 feature-showcase-card">
                    <div class="d-flex align-items-center mb-3">
                        <div class="logo-box me-3" style="width: 45px; height: 45px; font-size: 1.2rem; background: rgba(244, 63, 94, 0.15); color: #f43f5e;">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                        <div>
                            <h5 class="text-white fw-bold mb-0">Rezervasyon</h5>
                            <span class="text-muted small">Çalışma Alanı Yönetimi</span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-light opacity-75 small ps-2 border-start border-secondary border-opacity-25">
                        <li class="mb-2"><i class="fas fa-door-open text-danger me-2"></i> Akıllı Oda Tanımlama</li>
                        <li class="mb-2"><i class="fas fa-chair text-danger me-2"></i> Masa / Sandalye Slotları</li>
                        <li class="mb-2"><i class="fas fa-calendar-alt text-danger me-2"></i> İhlal ve Ceza Kontrolü</li>
                    </ul>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="hero-glass-card p-4 rounded-4 border-0 h-100 feature-showcase-card" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.08), rgba(0, 0, 0, 0));">
                    <div class="d-flex align-items-center mb-3">
                        <div class="logo-box me-3" style="width: 45px; height: 45px; font-size: 1.2rem; background: rgba(16, 185, 129, 0.2); color: #10b981;">
                            <i class="fas fa-shield-halved"></i>
                        </div>
                        <div>
                            <h5 class="text-white fw-bold mb-0">Güvenlik & Entegrasyon</h5>
                            <span class="text-muted small">Gelişmiş Arka Plan Servisleri</span>
                        </div>
                    </div>
                    <ul class="list-unstyled text-light opacity-75 small ps-2 border-start border-success border-opacity-25">
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i> 2-Factor (2FA) Giriş Güvenliği</li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Otomatik Haftalık Bulut Yedekleme</li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Detaylı Sistem Hareket Logları</li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i> ISBN Barkod ile Toplu Katalog Çekimi</li>
                        <li class="mb-1"><i class="fas fa-infinity text-success me-2"></i> Ve 20'den Fazla Gelişmiş Özellik</li>
                    </ul>
                </div>
            </div>

        </div>
    </section>


    <footer class="container relative-content text-center py-4 mt-4 border-top border-secondary border-opacity-25">
        <p class="text-muted small mb-0">&copy; 2026 Siber Kütüphane Otomasyon Projesi. Tüm Hakları Saklıdır .</p>
    </footer>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('tanitimGrafigi').getContext('2d');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran'],
                    datasets: [{
                        label: 'Ödünç Alınan',
                        data: [1200, 1900, 3200, 2500, 2800, 3850],
                        borderColor: '#00d2ff',
                        backgroundColor: 'rgba(0, 210, 255, 0.08)',
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3
                    }, {
                        label: 'İade Edilen',
                        data: [1000, 1500, 2800, 2400, 2200, 3100],
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16, 185, 129, 0.03)',
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: { color: '#94a3b8', font: { family: 'Plus Jakarta Sans', size: 11 } }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(255,255,255,0.03)', drawBorder: false },
                            ticks: { color: '#64748b', font: { size: 11 } }
                        },
                        y: {
                            grid: { color: 'rgba(255,255,255,0.03)', drawBorder: false },
                            ticks: { color: '#64748b', font: { size: 11 } }
                        }
                    }
                }
            });
        });
    </script>
   

</body>
</html>